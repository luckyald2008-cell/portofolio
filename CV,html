<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CV - Lucky Aldi Pratama</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .glass-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border: 1px solid rgba(229, 231, 235, 0.5); }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <nav class="fixed top-0 w-full z-50 glass-card shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="font-bold text-2xl text-blue-600 italic">LAP.</div>
                <div class="hidden md:flex space-x-8">
                    <a href="index.html" class="hover:text-blue-600">Profil</a>
                    <a href="cv.html" class="text-blue-600 font-bold">CV</a>
                    <a href="projects.html" class="hover:text-blue-600">Karya</a>
                    <a href="awards.html" class="hover:text-blue-600">Sertifikat</a>
                    <a href="reflection.html" class="hover:text-blue-600">Refleksi</a>
                    <a href="contact.html" class="hover:text-blue-600">Kontak</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="pt-32 pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-center mb-12">Curriculum Vitae</h2>
            <div class="grid md:grid-cols-2 gap-12">
                <div>
                    <h3 class="text-2xl font-bold mb-6"><i class="fas fa-graduation-cap text-blue-600 mr-3"></i> Pendidikan</h3>
                    <div class="border-l-2 border-blue-100 pl-8 space-y-8">
                        <div>
                            <h4 class="text-lg font-bold">Institusi Terkini</h4>
                            <p class="text-blue-600">2023 - Sekarang</p>
                            <p class="text-gray-600 mt-2">Fokus pada pengembangan diri di bidang IT.</p>
                        </div>
                    </div>
                </div>
                <div>
                    <h3 class="text-2xl font-bold mb-6"><i class="fas fa-award text-blue-600 mr-3"></i> Keahlian</h3>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg text-sm">HTML/CSS</span>
                        <span class="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg text-sm">Desain Grafis</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
